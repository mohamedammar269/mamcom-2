generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Contact {
  id        Int      @id @default(autoincrement())
  nom       String
  prenom    String
  email     String
  objet     String
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@map("contacts")
}

model Ceremonie {
  id            Int      @id @default(autoincrement())
  titre         String
  contenu       String   @db.Text
  imageUrl      String
  imagePublicId String
  date          String
  badge         String   @default("Cérémonie")
  createdAt     DateTime @default(now())

  @@map("ceremonies")
}
